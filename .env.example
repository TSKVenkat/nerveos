# NerveOS environment configuration
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────
APP_NAME=NerveOS
DEBUG=true
SECRET_KEY=change-this-in-production

# ── LLM ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Optional OpenAI fallback (leave empty to use only Ollama)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── SearXNG ─────────────────────────────────────────
SEARXNG_URL=http://localhost:8888

# ── Email (optional — for email agent) ──────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Database ────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nerveos.db

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Guardrails ──────────────────────────────────────
AUTO_APPROVE_SAFE_ACTIONS=false
MAX_DEAL_VALUE_AUTO_APPROVE=10000

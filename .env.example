# NerveOS environment configuration
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────
APP_NAME=NerveOS
DEBUG=true
SECRET_KEY=change-this-in-production

# ── LLM (Grok via OpenRouter) ────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=x-ai/grok-3-mini-beta
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── SearXNG ─────────────────────────────────────────
SEARXNG_URL=http://localhost:8888

# ── Email (optional — for email agent) ──────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# ── Database ────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nerveos.db

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Guardrails ──────────────────────────────────────
AUTO_APPROVE_SAFE_ACTIONS=false
MAX_DEAL_VALUE_AUTO_APPROVE=10000
